# --- SECURITY & CREDENTIALS ---
.env
.env.local
.env.*.local
*.key
*.pem
credentials.php
config/*.local.php

# --- DATABASE ---
# Don't commit raw SQL dumps containing real user/system data
database/*.sql
!database/schema.sql
!database/*.sample.sql

# --- AI & AGENT METADATA ---
.claude/
.agent/
.cursor/
.stitch/
.antigravity/
.gemini/
CLAUDE.md
*.jsonl

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- PHP/Web Runtime ---
pids
*.pid
*.seed
*.pid.lock
vendor/
node_modules/
bower_components/

# --- IDEs & Editors ---
.vscode/
.idea/
*.suo
*.sln
*.swp
*.swo
.project
.settings/
.buildpath

# --- OS Specific ---
.DS_Store
Thumbs.db
desktop.ini

# --- Build & Cache ---
dist/
build/
.cache/
.sass-cache/
.parcel-cache/
.next/
.vite-inspect
coverage/
.nyc_output
