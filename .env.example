# ==========================================
# SmartParking Pro - Environment Configuration
# ==========================================
# Duplicate this file to .env and fill in your details.

# --- Database Configuration ---
DB_HOST=localhost
DB_NAME=parking_db_v2
DB_USER=root
DB_PASS=

# --- AI Integration (OpenRouter) ---
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Recommended Models:
# - anthropic/claude-3.5-sonnet (Best for reasoning)
# - google/gemini-pro-1.5 (Fast and reliable)
# - meta-llama/llama-3-70b-instruct (Efficient)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Application Settings ---
APP_DEBUG=true
APP_URL=http://localhost/parking_system
TIMEZONE=Asia/Jakarta
